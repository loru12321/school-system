{
  "name": "school-desktop",
  "version": "1.0.1",
  "private": true,
  "description": "Windows desktop wrapper for SmartEdu Analytics",
  "main": "main.js",
  "author": "SmartEdu",
  "license": "ISC",
  "smartEduBuild": {
    "releaseTag": "school-system-v2026.04.09-about-update-v59",
    "releaseDate": "2026-04-09"
  },
  "scripts": {
    "sync:web": "powershell -ExecutionPolicy Bypass -File ./scripts/generate-icon.ps1 && node ./scripts/sync-bundle.mjs",
    "start": "npm run sync:web && electron .",
    "smoke": "npm run sync:web && electron . --smoke-test",
    "test:update-service": "node ./scripts/test-update-service.js",
    "build:dir": "npm run sync:web && electron-builder --win dir",
    "build:installer": "npm run sync:web && electron-builder --win nsis",
    "build:portable": "npm run sync:web && electron-builder --win portable",
    "build:win": "npm run build:installer"
  },
  "build": {
    "appId": "com.smartedu.desktop",
    "productName": "SmartEdu Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "*.js",
      "*.html",
      "bundle/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "bundle/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "smartedu-desktop-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智慧教务管理系统",
      "installerIcon": "bundle/app-icon.ico",
      "uninstallerIcon": "bundle/app-icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12"
  }
}
